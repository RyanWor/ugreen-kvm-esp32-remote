# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is gitignored — never commit real secrets.

wifi_ssid: "unused-for-ethernet"          # not used by the PoE build; kept for reference
wifi_password: "unused-for-ethernet"

# Generate a key in the ESPHome dashboard (it offers one when you adopt a
# device), or run:  openssl rand -base64 32
api_encryption_key: "PUT-YOUR-32-BYTE-BASE64-KEY-HERE"

# Any password you choose for OTA updates.
ota_password: "PUT-YOUR-OTA-PASSWORD-HERE"
